# Скопируй этот файл в .env и подставь свои значения.
# Ключи берутся на https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

TELEGRAM_SESSION_NAME=parser_session
LOG_LEVEL=INFO

# Бот-отправитель: токен из @BotFather и id группы-получателя.
# Бот должен быть добавлен в эту группу.
TELEGRAM_BOT_TOKEN=
OUTPUT_CHAT_ID=-
FORWARD_TO_GROUP=true

# Фильтрация по ключевым словам (правила — в filters.json).
# false = в группу уходит всё подряд, без фильтра.
FILTER_ENABLED=true

# ── LLM-слой: квалификация лида + черновик ответа ──
# По умолчанию ВКЛЮЧЕНО (умный режим). Нужен ключ DEEPSEEK_API_KEY ниже.
# Поставь false, чтобы вернуться к старому режиму (фильтр → сырой текст в группу).
LLM_ENABLED=true

# Какой провайдер: deepseek | anthropic
LLM_PROVIDER=deepseek

# DeepSeek (по умолчанию). Ключ: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash        # дёшево/быстро; качественнее — deepseek-v4-pro

# Anthropic (если LLM_PROVIDER=anthropic). Ключ: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Показывать техническую строку (оценка/тип/цена) в карточке: true | false
SHOW_TECH_LINE=true

# Минимальная категория лида для отправки в группу: hot | warm | cold | trash
# (всё, что ниже, не шлётся). По умолчанию warm и выше.
LLM_MIN_SCORE=warm

# CRM Bitrix24 (входящий вебхук). Как создать — см. CRM_SETUP.md
# URL вида: https://ВАШ-ПОРТАЛ.bitrix24.ru/rest/1/КОД/
# Требует LLM_ENABLED=true (в CRM пишем готовую карточку лида).
BITRIX_WEBHOOK_URL=
# По умолчанию ВКЛЮЧЕНО. Нужен BITRIX_WEBHOOK_URL выше; без него парсер просто
# не пишет в CRM (и предупреждает в логе). Поставь false, чтобы отключить совсем.
CRM_ENABLED=true
# Минимальная категория лида для попадания в CRM: hot | warm | cold | trash
CRM_MIN_SCORE=warm
